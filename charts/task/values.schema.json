{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "commonLabels": {
            "type": "object",
            "properties": {
                "admission.datadoghq.com/enabled": {
                    "type": "string"
                },
                "tags.datadoghq.com/service": {
                    "type": "string"
                },
                "tags.datadoghq.com/version": {
                    "type": "string"
                }
            }
        },
        "cronjobs": {
            "type": "object"
        },
        "image": {
            "type": "object",
            "properties": {
                "repository": {
                    "type": "string"
                },
                "tag": {
                    "type": "string"
                }
            }
        },
        "resources": {
            "type": "object",
            "properties": {
                "requests": {
                    "type": "object",
                    "properties": {
                        "cpu": {
                            "type": "string"
                        },
                        "memory": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "scheduling": {
            "type": "object",
            "properties": {
                "topologySpreadConstraints": {
                    "type": "array"
                }
            }
        },
        "service": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                }
            }
        },
        "workload": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string"
                }
            }
        }
    }
}
