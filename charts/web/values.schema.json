{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "configMap": {
            "type": "object",
            "properties": {
                "envFrom": {
                    "type": "boolean"
                }
            }
        },
        "gateway": {
            "type": "object",
            "properties": {
                "httpRoute": {
                    "type": "object",
                    "properties": {
                        "enabled": {
                            "type": "boolean"
                        },
                        "hostnames": {
                            "type": "array"
                        },
                        "parentRefs": {
                            "type": "array"
                        },
                        "rules": {
                            "type": "array"
                        }
                    }
                },
                "loadBalancerConfiguration": {
                    "type": "object",
                    "properties": {
                        "enabled": {
                            "type": "boolean"
                        }
                    }
                },
                "targetGroupConfiguration": {
                    "type": "object",
                    "properties": {
                        "defaultConfiguration": {
                            "type": "object",
                            "properties": {
                                "healthCheckConfig": {
                                    "type": "object",
                                    "properties": {
                                        "healthCheckInterval": {
                                            "type": "integer"
                                        },
                                        "healthCheckPath": {
                                            "type": "string"
                                        },
                                        "healthCheckProtocol": {
                                            "type": "string"
                                        },
                                        "healthyThresholdCount": {
                                            "type": "integer"
                                        },
                                        "unhealthyThresholdCount": {
                                            "type": "integer"
                                        }
                                    }
                                },
                                "protocolVersion": {
                                    "type": "string"
                                },
                                "targetType": {
                                    "type": "string"
                                }
                            }
                        },
                        "enabled": {
                            "type": "boolean"
                        }
                    }
                }
            }
        },
        "hpa": {
            "type": "object",
            "properties": {
                "minReplicas": {
                    "type": "integer"
                }
            }
        },
        "image": {
            "type": "object",
            "properties": {
                "repository": {
                    "type": "string"
                },
                "tag": {
                    "type": "string"
                }
            }
        },
        "livenessProbe": {
            "type": "object",
            "properties": {
                "failureThreshold": {
                    "type": "integer"
                },
                "httpGet": {
                    "type": "object",
                    "properties": {
                        "path": {
                            "type": "string"
                        },
                        "port": {
                            "type": "string"
                        }
                    }
                },
                "initialDelaySeconds": {
                    "type": "integer"
                },
                "periodSeconds": {
                    "type": "integer"
                },
                "timeoutSeconds": {
                    "type": "integer"
                }
            }
        },
        "port": {
            "type": "integer"
        },
        "readinessProbe": {
            "type": "object",
            "properties": {
                "failureThreshold": {
                    "type": "integer"
                },
                "httpGet": {
                    "type": "object",
                    "properties": {
                        "path": {
                            "type": "string"
                        },
                        "port": {
                            "type": "string"
                        }
                    }
                },
                "initialDelaySeconds": {
                    "type": "integer"
                },
                "periodSeconds": {
                    "type": "integer"
                },
                "timeoutSeconds": {
                    "type": "integer"
                }
            }
        },
        "resources": {
            "type": "object",
            "properties": {
                "requests": {
                    "type": "object",
                    "properties": {
                        "cpu": {
                            "type": "string"
                        },
                        "memory": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "scheduling": {
            "type": "object",
            "properties": {
                "nodeSelector": {
                    "type": "object",
                    "properties": {
                        "kubernetes.io/arch": {
                            "type": "string"
                        }
                    }
                },
                "topologySpreadConstraints": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "maxSkew": {
                                "type": "integer"
                            },
                            "topologyKey": {
                                "type": "string"
                            },
                            "whenUnsatisfiable": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "service": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "port": {
                    "type": "integer"
                },
                "type": {
                    "type": "string"
                }
            }
        },
        "startupProbe": {
            "type": "object",
            "properties": {
                "failureThreshold": {
                    "type": "integer"
                },
                "httpGet": {
                    "type": "object",
                    "properties": {
                        "path": {
                            "type": "string"
                        },
                        "port": {
                            "type": "string"
                        }
                    }
                },
                "initialDelaySeconds": {
                    "type": "integer"
                },
                "periodSeconds": {
                    "type": "integer"
                },
                "timeoutSeconds": {
                    "type": "integer"
                }
            }
        }
    }
}
